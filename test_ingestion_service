import sys
import os
import json
from pathlib import Path
from unittest.mock import Mock, patch
from ..services.ingestion_service import IngestionService

def test_ingest_json(json_dir: str):
    """Test ingest_json with actual data from the specified directory."""
    
    json_path = Path(json_dir)
    
    if not json_path.exists():
        print(f"Error: JSON file not found at {json_path}")
        return
    
    # Load data
    with open(json_path, "r", encoding="utf-8") as f:
        data = json.load(f)
    
    print(f"✓ Loaded data from {json_path}\n")
    
    # Create service with actual embedder
    service = IngestionService(
        repo=None,
        embedder=None,  # Use actual embedder
        version="test-v1"
    )
    
    # Run ingestion
    print("=" * 80)
    print("TEST: INGEST_JSON")
    print("=" * 80)
    
    record_count, records = service.ingest_json(
        data=data,
        source_id="test_source",
        title="Test Data"
    )
    
    print(f"\n✓ Ingestion complete")
    print(f"Total records created: {record_count}")
    print(f"Records returned: {len(records)}")
    
    # Print first 3 records
    preview_count = min(3, len(records))
    print(f"\nFirst {preview_count} records:")
    print("=" * 80)
    for i in range(preview_count):
        record = records[i]
        print(f"\nRecord {i + 1}:")
        print(f"  chunk_id: {record.chunk_id}")
        print(f"  source_id: {record.source_id}")
        print(f"  text preview: {record.text[:300]}...")
        print("-" * 80)
    
    print(f"\n✓ Test completed successfully")


if __name__ == "__main__":
    test_ingest_json("./data/accommodation_halls.json")